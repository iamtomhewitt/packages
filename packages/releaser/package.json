{
  "name": "@iamtomhewitt/releaser",
  "version": "3.1.1",
  "author": "Tom Hewitt",
  "main": "index.js",
  "type": "module",
  "bin": {
    "iamtomhewitt-releaser": "index.js"
  },
  "scripts": {
    "build": "rm -rf dist && ts-node build.ts",
    "lint": "ts-node ../linter/dist/index.js --sourceFolder=./ --type=typescript",
    "lint-fix": "npm run lint -- --fix",
    "postbuild": "cp package.json dist && cp README.md dist"
  },
  "dependencies": {
    "args-parser": "1.3.0"
  },
  "devDependencies": {
    "@tsconfig/node24": "24.0.4",
    "@types/node": "25.6.0",
    "esbuild": "0.28.0",
    "ts-node": "10.9.2",
    "typescript": "6.0.3"
  }
}