{
  "name": "@iamtomhewitt/linter",
  "version": "2.1.2",
  "author": "Tom Hewitt",
  "main": "index.js",
  "type": "module",
  "bin": {
    "iamtomhewitt-linter": "index.js"
  },
  "scripts": {
    "build": "rm -rf dist && ts-node build.ts",
    "lint": "ts-node ../linter/dist/index.js --sourceFolder=./ --type=typescript",
    "lint-fix": "npm run lint -- --fix",
    "postbuild": "cp package.json dist && cp README.md dist"
  },
  "dependencies": {
    "@typescript-eslint/eslint-plugin": "5.53.0",
    "@typescript-eslint/parser": "5.54.0",
    "args-parser": "1.3.0",
    "chalk": "5.6.2",
    "eslint": "8.57.0",
    "eslint-plugin-prefer-arrow": "1.2.3",
    "eslint-plugin-react": "7.37.5",
    "markdownlint": "0.40.0",
    "node-fetch": "3.3.2",
    "stylelint": "17.9.0",
    "stylelint-config-standard": "40.0.0",
    "stylelint-config-standard-scss": "17.0.0",
    "stylelint-order": "8.1.1"
  },
  "devDependencies": {
    "@tsconfig/node24": "24.0.4",
    "@types/eslint": "8.56.12",
    "@types/node": "25.6.0",
    "esbuild": "0.28.0",
    "ts-node": "10.9.2",
    "typescript": "6.0.3"
  }
}